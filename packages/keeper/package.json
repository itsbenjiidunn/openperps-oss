{
  "name": "@openperps/keeper",
  "version": "1.4.1",
  "description": "Core-only self-host keeper for OpenPerps: oracle/funding cranks and liquidation, across many markets.",
  "license": "Apache-2.0",
  "author": "itsbenjiidunn",
  "homepage": "https://github.com/itsbenjiidunn/openperps-oss/tree/main/packages/keeper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsbenjiidunn/openperps-oss.git",
    "directory": "packages/keeper"
  },
  "bugs": {
    "url": "https://github.com/itsbenjiidunn/openperps-oss/issues"
  },
  "keywords": [
    "solana",
    "perpetuals",
    "perps",
    "defi",
    "keeper",
    "oracle",
    "liquidation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "openperps-relayer": "./dist/bin/relayer.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-extensions.mjs dist",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx \"test/**/*.test.ts\"",
    "relayer": "tsx src/bin/relayer.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@openperps/sdk": "^1.4.1",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
