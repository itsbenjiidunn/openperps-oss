{
  "name": "@openperps/sdk",
  "version": "1.4.0",
  "description": "TypeScript SDK for the OpenPerps on-chain program.",
  "license": "Apache-2.0",
  "author": "itsbenjiidunn",
  "homepage": "https://github.com/itsbenjiidunn/openperps-oss/tree/main/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsbenjiidunn/openperps-oss.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/itsbenjiidunn/openperps-oss/issues"
  },
  "keywords": [
    "solana",
    "perpetuals",
    "perps",
    "defi",
    "trading",
    "sdk",
    "web3"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-extensions.mjs dist",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx \"test/**/*.test.ts\"",
    "smoke": "tsx scripts/smoke.ts",
    "hlp-integration": "tsx scripts/hlp-integration.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
