# OpenPerps OSS environment template. Copy to .env and fill in.
# .env is gitignored: NEVER commit real secret values, even to a private repo
# (git history is permanent). Share the secret-marked values out of band
# (a shared password manager / vault), not in git.

# --- Shared config (not secret) ---
# RPC endpoint. Public devnet, or your own Helius/QuickNode devnet URL.
OPENPERPS_RPC=https://api.devnet.solana.com
# Canonical devnet program id (also exported as DEVNET_PROGRAM_ID from the SDK).
OPENPERPS_PROGRAM_ID=2TGY1iY2r4MKytwg5vir9CJnJrqgdZrzjF8LjNaiVnZ4
# Collateral mint (quote) for your markets.
OPENPERPS_QUOTE_MINT=
# Keeper / relayer tuning.
OPENPERPS_INTERVAL_MS=2000
OPENPERPS_HEALTH_PORT=18810
OPENPERPS_HEALTH_HOST=0.0.0.0
# Path to a markets json (array of OpenPerpsMarketConfig from createPerpMarket).
OPENPERPS_MARKETS=./markets.json

# --- Keypairs (SECRET: generate your OWN; do not share the upgrade authority) ---
# A funded devnet keypair you control (generate with `solana-keygen new`, then
# fund via the faucet). Each dev uses their own; do NOT reuse the deploy/upgrade
# authority keypair, which controls the live program and must stay in a vault.
OPENPERPS_PAYER=./payer.json
OPENPERPS_KEEPER_KEYPAIR=./keeper.json

# --- Indexer secrets (SECRET: receive from the team vault if you run the indexer) ---
# Oracle relayer signing key (JSON secret-key array) for AccrueAsset pushes.
RELAYER_SECRET=
# Bearer token gating the indexer admin endpoints.
ADMIN_SECRET=
# Indexer RPC (may differ from the keeper RPC).
RPC_URL=https://api.devnet.solana.com
